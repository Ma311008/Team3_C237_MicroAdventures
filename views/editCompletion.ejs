<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <title>Edit Entry</title>
</head>
<body>
  <%- include('partials/navbar.ejs') %>

  <div class="container mt-5" style="max-width: 600px;">

  <div class="card shadow">
    <div class="card-body">
    <h1>Edit My Entry</h1>
    <% if(successMsg && successMsg.length){ %>

<div class="alert alert-success">

<%= successMsg[0] %>

</div>

<% } %>

<% if(errorMsg && errorMsg.length){ %>

<div class="alert alert-danger">

<%= errorMsg[0] %>

</div>

<% } %>
    <form action="/completions/<%= completion.id %>/edit" method="POST" class="mt-4">
      <div class="form-group mb-3">
        <label for="completed_at">Date completed:</label>
        <input type="date" id="completed_at" name="completed_at" class="form-control"
               value="<%= completion.completed_at.toISOString().split('T')[0] %>" required>
      </div>
      <div class="form-group mb-3">

<label for="rating">

Rating

</label>

<select
name="rating"
class="form-select">

<option value="1"
<%= completion.rating==1 ? "selected" : "" %>>

★☆☆☆☆

</option>

<option value="2"
<%= completion.rating==2 ? "selected" : "" %>>

★★☆☆☆

</option>

<option value="3"
<%= completion.rating==3 ? "selected" : "" %>>

★★★☆☆

</option>

<option value="4"
<%= completion.rating==4 ? "selected" : "" %>>

★★★★☆

</option>

<option value="5"
<%= completion.rating==5 ? "selected" : "" %>>

★★★★★

</option>

</select>

</div>
      <div class="form-group mb-3">
        <label for="notes">Notes:</label>
        <textarea
id="notes"
name="notes"
class="form-control"
maxlength="300"
placeholder="Share your experience..."><%= completion.notes %></textarea>
      </div>
      <button type="submit" class="btn btn-primary">Save Changes</button>
        </form>

    </div>
  </div>

</div>
</body>
</html>
