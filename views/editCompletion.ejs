<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <title>Edit Entry</title>
</head>
<body>
  <%- include('partials/navbar.ejs') %>

  <div class="container mt-5" style="max-width: 600px;">
    <h1>Edit My Entry</h1>
    <form action="/completions/<%= completion.id %>/edit" method="POST" class="mt-4">
      <div class="form-group mb-3">
        <label for="completed_at">Date completed:</label>
        <input type="date" id="completed_at" name="completed_at" class="form-control"
               value="<%= completion.completed_at.toISOString().split('T')[0] %>" required>
      </div>
      <div class="form-group mb-3">
        <label for="rating">Rating (1-5):</label>
        <input type="number" id="rating" name="rating" min="1" max="5" class="form-control" value="<%= completion.rating %>">
      </div>
      <div class="form-group mb-3">
        <label for="notes">Notes:</label>
        <textarea id="notes" name="notes" class="form-control"><%= completion.notes %></textarea>
      </div>
      <button type="submit" class="btn btn-primary">Save Changes</button>
    </form>
  </div>
</body>
</html>
