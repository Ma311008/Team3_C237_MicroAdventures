<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
  <title>Leaderboard</title>
</head>
<body>
  <%- include('partials/navbar.ejs') %>

  <div class="container mt-5" style="max-width: 700px;">
    <div class="text-center mb-4">
      <h1>&#127942; Top Explorers</h1>
      <p class="text-muted">Ranked by number of experiences reviewed.</p>
    </div>

    <div class="card shadow-sm">
      <div class="card-header text-white" style="background: var(--brand-gradient);">
        Leaderboard
      </div>
      <div class="card-body p-0">
        <% if (leaders.length === 0) { %>
          <div class="alert alert-info text-center m-3 mb-0">No reviews yet - be the first to explore!</div>
        <% } else { %>
          <ul class="list-group list-group-flush">
            <% leaders.forEach(function(leader, index) { %>
              <% const medal = index === 0 ? '&#129351;' : index === 1 ? '&#129352;' : index === 2 ? '&#129353;' : null; %>
              <li class="list-group-item d-flex align-items-center justify-content-between <%= index < 3 ? 'bg-light' : '' %>">
                <div class="d-flex align-items-center gap-3">
                  <span class="fs-4" style="width: 2.5rem; text-align: center;">
                    <%- medal || ('#' + (index + 1)) %>
                  </span>
                  <div>
                    <strong><%= leader.username %></strong>
                    <div class="text-muted small"><%= leader.total_reviews %> review<%= leader.total_reviews == 1 ? '' : 's' %> written</div>
                  </div>
                </div>
                <span class="badge bg-warning text-dark fs-6">
                  &#9733; <%= leader.avg_rating_given %>/5
                </span>
              </li>
            <% }); %>
          </ul>
        <% } %>
      </div>
    </div>
  </div>
</body>
</html>
