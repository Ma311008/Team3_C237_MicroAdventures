<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <title>My Progress</title>
</head>
<body>
  <%- include('partials/navbar.ejs') %>

  <div class="container mt-5">
    <h1>My Progress</h1>

    <% if (badges.length > 0) { %>
      <div class="alert alert-warning mt-3">
        <strong>Badges earned:</strong>
        <% badges.forEach(function(b) { %>
          <span class="badge bg-warning text-dark"><%= b.category %> Explorer (<%= b.total %>)</span>
        <% }); %>
      </div>
    <% } %>

    <table class="table mt-4">
      <thead>
        <tr>
          <th>Title</th>
          <th>Category</th>
          <th>Completed On</th>
          <th>Rating</th>
          <th>Notes</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% completed.forEach(function(item) { %>
          <tr>
            <td><a href="/experiences/<%= item.id %>"><%= item.title %></a></td>
            <td><%= item.category %></td>
            <td><%= item.completed_at.toISOString().split('T')[0] %></td>
            <td><%= item.rating || '-' %></td>
            <td><%= item.notes || '-' %></td>
          </tr>
        <% }); %>
        <% if (completed.length === 0) { %>
          <tr><td colspan="5">You haven't completed any experiences yet. <a href="/explore">Start exploring!</a></td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</body>
</html>
