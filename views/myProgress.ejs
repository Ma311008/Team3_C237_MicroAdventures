<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Progress</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
</head>

<body>

<%- include('partials/navbar.ejs') %>

<div class="container mt-5">

    <% if (successMsg && successMsg.length > 0) { %>
        <div class="alert alert-success">
            <% successMsg.forEach(function(message) { %>
                <p class="mb-0"><%= message %></p>
            <% }); %>
        </div>
    <% } %>

    <% if (errorMsg && errorMsg.length > 0) { %>
        <div class="alert alert-danger">
            <% errorMsg.forEach(function(message) { %>
                <p class="mb-0"><%= message %></p>
            <% }); %>
        </div>
    <% } %>

    <div class="text-center mb-4">
        <h1>My Progress</h1>
        <p class="text-muted">
            View your completed adventures and earned badges.
        </p>
    </div>

    <!-- Badges -->
    <div class="card shadow-sm mb-4">

        <div class="card-header text-white" style="background: var(--brand-gradient);">
            🏅 Earned Badges
        </div>

        <div class="card-body">

            <% if (badges.length > 0) { %>

                <% badges.forEach(function(badge){ %>

                    <span class="badge me-2 mb-2 fs-6 text-white" style="background: var(--brand-gradient);">
                        <%= badge.category.charAt(0).toUpperCase() + badge.category.slice(1) %> Explorer
                    </span>

                <% }) %>

            <% } else { %>

                <p class="text-muted mb-0">
                    No badges earned yet. Complete 5 experiences in the same category to unlock one.
                </p>

            <% } %>

        </div>

    </div>

    <!-- Completed Experiences -->

    <div class="card shadow-sm">

        <div class="card-header text-white" style="background: linear-gradient(135deg, #10b981 0%, #34d399 100%);">
            ✅ Completed Experiences
        </div>

        <div class="card-body">

            <% if (completed.length > 0) { %>

                <div class="table-responsive">

                    <table class="table table-hover align-middle">

                        <thead>

                            <tr>

                                <th>Photo</th>
                                <th>Title</th>
                                <th>Category</th>
                                <th>Rating</th>
                                <th>Notes</th>
                                <th>Completed On</th>
                                <th>Actions</th>

                            </tr>

                        </thead>

                        <tbody>

                            <% completed.forEach(function(exp){ %>

                                <tr>

                                    <td>
                                        <% if (exp.image) { %>
                                            <img src="/images/<%= exp.image %>" alt="<%= exp.title %>" class="rounded" style="width: 60px; height: 60px; object-fit: cover;">
                                        <% } else { %>
                                            <span class="text-muted">&mdash;</span>
                                        <% } %>
                                    </td>

                                    <td>

                                        <strong><%= exp.title %></strong>

                                    </td>

                                    <td>
                                        <% const categoryClass = { food: 'bg-warning text-dark', nature: 'bg-success', culture: 'bg-info text-dark', nightlife: 'bg-dark', shopping: 'bg-danger' }[exp.category] || 'bg-primary'; %>
                                        <span class="badge <%= categoryClass %>">

                                            <%= exp.category %>

                                        </span>

                                    </td>

                                    <td>

                                        <%= exp.rating %>/5 ⭐

                                    </td>

                                    <td>

                                        <%= exp.notes || "No notes" %>

                                    </td>

                                    <td>

                                        <%= new Date(exp.completed_at).toLocaleDateString() %>

                                    </td>

                                    <td>

                                        <% if (exp.completion_id) { %>

                                            <form action="/completions/<%= exp.completion_id %>/delete"
                                                  method="POST"
                                                  class="d-inline">

                                                <button type="submit"
                                                        class="btn btn-sm btn-outline-danger"
                                                        onclick="return confirm('Remove this completion from your list?')">

                                                    Delete

                                                </button>

                                            </form>

                                        <% } %>

                                    </td>

                                </tr>

                            <% }) %>

                        </tbody>

                    </table>

                </div>

            <% } else { %>

                <div class="alert alert-info text-center">

                    You haven't completed any experiences yet.

                </div>

            <% } %>

        </div>

    </div>

    <div class="mt-4">

        <a href="/explore" class="btn btn-secondary">

            ← Back to Explore

        </a>

    </div>

</div>

</body>
</html>