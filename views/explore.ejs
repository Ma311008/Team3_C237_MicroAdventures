<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <title>Explore</title>
</head>
<body>
  <%- include('partials/navbar.ejs') %>

  <div class="container mt-5">
    <h1>Explore Experiences</h1>

    <form action="/search" method="GET" class="row g-2 mt-3 mb-4">
      <div class="col-auto">
        <select name="category" class="form-select">
          <option value="">All categories</option>
          <option value="food" <%= query.category === 'food' ? 'selected' : '' %>>Food</option>
          <option value="nature" <%= query.category === 'nature' ? 'selected' : '' %>>Nature</option>
          <option value="culture" <%= query.category === 'culture' ? 'selected' : '' %>>Culture</option>
          <option value="nightlife" <%= query.category === 'nightlife' ? 'selected' : '' %>>Nightlife</option>
          <option value="shopping" <%= query.category === 'shopping' ? 'selected' : '' %>>Shopping</option>
        </select>
      </div>
      <div class="col-auto">
        <select name="sort" class="form-select">
          <option value="newest" <%= query.sort === 'newest' ? 'selected' : '' %>>Newest first</option>
          <option value="title" <%= query.sort === 'title' ? 'selected' : '' %>>Title A-Z</option>
        </select>
      </div>
      <div class="col-auto">
        <button type="submit" class="btn btn-secondary">Filter</button>
      </div>
    </form>

    <div class="row">
      <% experiences.forEach(function(exp) { %>
        <div class="col-md-4 mb-4">
          <div class="card h-100">
            <div class="card-body">
              <h5 class="card-title"><%= exp.title %></h5>
              <h6 class="card-subtitle mb-2 text-muted"><%= exp.category %> &middot; <%= exp.difficulty %></h6>
              <p class="mb-1">
                <% if (exp.review_count > 0) { %>
                  &#9733; <%= exp.avg_rating %> <span class="text-muted">(<%= exp.review_count %> review<%= exp.review_count == 1 ? '' : 's' %>)</span>
                <% } else { %>
                  <span class="text-muted">No reviews yet</span>
                <% } %>
              </p>
              <p class="card-text"><%= exp.location %></p>
              <a href="/experiences/<%= exp.id %>" class="btn btn-primary btn-sm">View</a>
              <% if (user.role === 'admin') { %>
                <a href="/experiences/<%= exp.id %>/edit" class="btn btn-outline-secondary btn-sm">Edit</a>
                <form action="/experiences/<%= exp.id %>/delete" method="POST" class="d-inline">
                  <button type="submit" class="btn btn-outline-danger btn-sm" onclick="return confirm('Delete this experience?')">Delete</button>
                </form>
              <% } %>
            </div>
          </div>
        </div>
      <% }); %>
      <% if (experiences.length === 0) { %>
        <p>No experiences found.</p>
      <% } %>
    </div>
  </div>
</body>
</html>
