<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>Explore Experiences</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</head>

<body>

  <%- include('partials/navbar.ejs') %>

  <div class="container mt-5">

    <div class="text-center mb-4">
      <h1>Explore Experiences</h1>
      <p class="text-muted">
        Discover exciting micro-adventures around Singapore.
      </p>
    </div>

    <!-- Filter -->
    <form action="/search" method="GET" class="row g-2 mb-4">

      <div class="col-md-3">
        <select name="category" class="form-select">
          <option value="">All Categories</option>

          <option value="food"
            <%= query && query.category === 'food' ? 'selected' : '' %>>
            Food
          </option>

          <option value="nature"
            <%= query && query.category === 'nature' ? 'selected' : '' %>>
            Nature
          </option>

          <option value="culture"
            <%= query && query.category === 'culture' ? 'selected' : '' %>>
            Culture
          </option>

          <option value="nightlife"
            <%= query && query.category === 'nightlife' ? 'selected' : '' %>>
            Nightlife
          </option>

          <option value="shopping"
            <%= query && query.category === 'shopping' ? 'selected' : '' %>>
            Shopping
          </option>

        </select>
      </div>

      <div class="col-md-3">

        <select name="sort" class="form-select">

          <option value="newest"
            <%= query && query.sort === 'newest' ? 'selected' : '' %>>
            Newest First
          </option>

          <option value="title"
            <%= query && query.sort === 'title' ? 'selected' : '' %>>
            Title A-Z
          </option>

        </select>

      </div>

      <div class="col-md-2">
        <button class="btn btn-secondary w-100">
          Filter
        </button>
      </div>

    </form>

    <div class="row">

      <% if (experiences.length > 0) { %>

        <% experiences.forEach(function(exp){ %>

          <div class="col-md-4 mb-4">

            <div class="card shadow-sm h-100">

              <div class="card-body d-flex flex-column">

                <h4 class="card-title">
                  <%= exp.title %>
                </h4>

                <span class="badge bg-primary mb-2">
                  <%= exp.category.charAt(0).toUpperCase() + exp.category.slice(1) %>
                </span>

                <p class="text-muted mb-2">

                  Difficulty:
                  <strong><%= exp.difficulty %></strong>

                </p>

                <p>

                  📍 <%= exp.location %>

                </p>

                <div class="mt-auto">

                  <a href="/experiences/<%= exp.id %>"
                     class="btn btn-primary w-100 mb-2">

                    View Details

                  </a>

                  <% if(user.role === 'admin'){ %>

                    <a href="/experiences/<%= exp.id %>/edit"
                       class="btn btn-outline-secondary w-100 mb-2">

                      Edit

                    </a>

                    <form action="/experiences/<%= exp.id %>/delete"
                          method="POST">

                      <button
                        class="btn btn-outline-danger w-100"
                        onclick="return confirm('Delete this experience?')">

                        Delete

                      </button>

                    </form>

                  <% } %>

                </div>

              </div>

            </div>

          </div>

        <% }) %>

      <% } else { %>

        <div class="col-12">

          <div class="alert alert-info text-center">

            No experiences found.

          </div>

        </div>

      <% } %>

    </div>

  </div>

</body>
</html>