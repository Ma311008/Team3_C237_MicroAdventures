<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
  <title>Micro-Adventures</title>
</head>
<body>
  <%- include('partials/navbar.ejs') %>

  <div class="container mt-5 text-center">
    <h1>Local Micro-Adventure Bucket List</h1>
    <% if (user) { %>
      <p class="mt-3">Welcome back, <%= user.username %>! Continue <a href="/explore">exploring</a>.</p>
    <% } else { %>
      <p class="mt-3">Discover local spots and experiences. Please <a href="/login">login</a> or <a href="/register">register</a> to start tracking your adventures.</p>
    <% } %>
  </div>
</body>
</html>
