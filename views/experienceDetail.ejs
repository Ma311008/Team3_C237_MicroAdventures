<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= experience.title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body>
<%- include('partials/navbar.ejs') %>

<%
  const categoryEmoji = { food: '🍜', nature: '🌳', culture: '🎭', nightlife: '🌃', shopping: '🛍️' }[experience.category] || '📍';
  const categoryClass = { food: 'bg-warning text-dark', nature: 'bg-success', culture: 'bg-info text-dark', nightlife: 'bg-dark', shopping: 'bg-danger' }[experience.category] || 'bg-primary';
  const difficultyClass = { easy: 'bg-success', moderate: 'bg-warning text-dark', challenging: 'bg-danger' }[experience.difficulty] || 'bg-secondary';
%>

<main class="container my-5">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <% if (successMsg && successMsg.length > 0) { %>
        <div class="alert alert-success">
          <% successMsg.forEach(function(message) { %><p class="mb-0"><%= message %></p><% }); %>
        </div>
      <% } %>
      <% if (errorMsg && errorMsg.length > 0) { %>
        <div class="alert alert-danger">
          <% errorMsg.forEach(function(message) { %><p class="mb-0"><%= message %></p><% }); %>
        </div>
      <% } %>

      <div class="card shadow overflow-hidden">
        <div class="p-4 p-md-5 text-white" style="background: var(--brand-gradient);">
          <div class="fs-1 mb-2"><%= categoryEmoji %></div>
          <h1 class="h2 mb-1"><%= experience.title %></h1>
          <p class="mb-0 opacity-75">&#128205; <%= experience.location %></p>
        </div>
        <div class="card-body">
          <div class="d-flex align-items-center flex-wrap gap-2 mb-3">
            <span class="badge <%= categoryClass %>">
              <%= experience.category.charAt(0).toUpperCase() + experience.category.slice(1) %>
            </span>
            <span class="badge <%= difficultyClass %>">
              <%= experience.difficulty.charAt(0).toUpperCase() + experience.difficulty.slice(1) %>
            </span>
            <% if (experience.review_count > 0) { %>
              <span class="badge bg-warning text-dark">
                &#9733; <%= experience.avg_rating %> <span class="fw-normal">(<%= experience.review_count %> review<%= experience.review_count == 1 ? '' : 's' %>)</span>
              </span>
            <% } else { %>
              <span class="badge bg-light text-muted border">No reviews yet - be the first!</span>
            <% } %>
          </div>

          <p class="card-text mb-0"><%= experience.description %></p>
        </div>
      </div>

      <% if (user.role === 'explorer') { %>
        <div class="mt-4">
          <% if (!completion) { %>
            <div class="card shadow">
              <div class="card-body">
                <h4>&#128221; Mark Experience as Completed</h4>
                <p class="text-muted">Record when you completed this adventure and how you would rate it.</p>
                <form action="/experiences/<%= experience.id %>/complete" method="POST" enctype="multipart/form-data" id="completionForm">
                  <div class="mb-3">
                    <label for="rating" class="form-label">Rating *</label>
                    <select id="rating" name="rating" class="form-select" required>
                      <option value="">Select a rating</option>
                      <option value="1">1 - Lowest</option>
                      <option value="2">2</option>
                      <option value="3">3</option>
                      <option value="4">4</option>
                      <option value="5">5 - Highest</option>
                    </select>
                    <div class="form-text">1 is the lowest rating and 5 is the highest.</div>
                  </div>
                  <div class="mb-3">
                    <label for="notes" class="form-label">Notes</label>
                    <textarea id="notes" name="notes" rows="4" maxlength="500" class="form-control"
                              placeholder="Share your experience..."></textarea>
                    <div class="form-text">Optional, up to 500 characters.</div>
                  </div>
                  <div class="mb-3">
                    <label for="image" class="form-label">Photo</label>
                    <input type="file" id="image" name="image" accept="image/*" class="form-control">
                    <div class="form-text">Optional - share a photo from your visit.</div>
                  </div>
                  <div class="mb-3">
                    <label for="completed_at" class="form-label">Completion date *</label>
                    <input type="date" id="completed_at" name="completed_at" class="form-control" required>
                    <div class="form-text">The date cannot be later than today.</div>
                  </div>
                  <button type="submit" class="btn btn-success w-100" id="completionSubmitButton">
                    Mark as Completed
                  </button>
                </form>
              </div>
            </div>
          <% } else { %>
            <div class="card border-success shadow">
              <div class="card-body">
                <h4 class="text-success">&#9989; You have already completed this experience.</h4>
                <hr>
                <% if (completion.image) { %>
                  <img src="/images/<%= completion.image %>" alt="Your photo" class="img-fluid rounded mb-3" style="max-height: 300px;">
                <% } %>
                <p class="mb-2">&#9733; <strong><%= completion.rating %>/5</strong></p>
                <p><strong>Your Notes:</strong><br><%= completion.notes || 'No notes added.' %></p>
                <p class="text-muted small">Completed on <%= new Date(completion.completed_at).toLocaleDateString() %></p>
                <a href="/completions/<%= completion.id %>/edit" class="btn btn-outline-primary btn-sm">
                  Edit completion
                </a>
              </div>
            </div>
          <% } %>
        </div>
      <% } else if (user.role === 'admin') { %>
        <div class="alert alert-info mt-4 mb-0">
          Completion tracking is available to explorer accounts.
        </div>
      <% } %>

      <div class="card shadow mt-4">
        <div class="card-body">
          <h4 class="mb-3">&#128172; Reviews</h4>
          <% if (reviews.length === 0) { %>
            <p class="text-muted mb-0">No one has reviewed this yet.</p>
          <% } else { %>
            <% reviews.forEach(function(review) { %>
              <div class="d-flex gap-3 py-3 border-bottom">
                <div class="rounded-circle d-flex align-items-center justify-content-center text-white flex-shrink-0"
                     style="width: 42px; height: 42px; background: var(--brand-gradient); font-weight: 600;">
                  <%= review.username.charAt(0).toUpperCase() %>
                </div>
                <div class="flex-grow-1">
                  <div class="d-flex align-items-center flex-wrap gap-2">
                    <strong><%= review.username %></strong>
                    <% if (review.rating) { %><span class="badge bg-warning text-dark">&#9733; <%= review.rating %>/5</span><% } %>
                    <span class="text-muted small"><%= new Date(review.completed_at).toLocaleDateString() %></span>
                  </div>
                  <% if (review.notes) { %><p class="mb-2 mt-1"><%= review.notes %></p><% } %>
                  <% if (review.image) { %>
                    <img src="/images/<%= review.image %>" alt="Photo from <%= review.username %>" class="img-fluid rounded" style="max-height: 220px;">
                  <% } %>
                </div>
              </div>
            <% }); %>
          <% } %>
        </div>
      </div>

      <div class="mt-4">
        <a href="/explore" class="btn btn-secondary">&larr; Back to Explore</a>
      </div>
    </div>
  </div>
</main>

<script>
  const completionDate = document.getElementById('completed_at');
  if (completionDate) {
    const now = new Date();
    const localToday = new Date(now.getTime() - now.getTimezoneOffset() * 60000)
      .toISOString().split('T')[0];
    completionDate.max = localToday;
    completionDate.value = localToday;
  }

  const completionForm = document.getElementById('completionForm');
  if (completionForm) {
    completionForm.addEventListener('submit', function () {
      if (!this.checkValidity()) return;
      const button = document.getElementById('completionSubmitButton');
      button.disabled = true;
      button.textContent = 'Saving...';
    });
  }
</script>
</body>
</html>
