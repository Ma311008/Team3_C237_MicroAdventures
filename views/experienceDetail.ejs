<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= experience.title %></title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</head>

<body>

<%- include('partials/navbar.ejs') %>

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-lg-8">

            <div class="card shadow">

                <div class="card-body">

                    <h2 class="card-title mb-3">
                        <%= experience.title %>
                    </h2>

                    <span class="badge bg-primary mb-3">
                        <%= experience.category.charAt(0).toUpperCase() + experience.category.slice(1) %>
                    </span>

                    <p class="card-text">
                        <strong>Description:</strong><br>
                        <%= experience.description %>
                    </p>

                    <hr>

                    <div class="row">

                        <div class="col-md-6 mb-3">
                            <strong>📍 Location</strong><br>
                            <%= experience.location %>
                        </div>

                        <div class="col-md-6 mb-3">
                            <strong>⭐ Difficulty</strong><br>
                            <%= experience.difficulty %>
                        </div>

                    </div>

                </div>

            </div>

            <!-- Explorer Only -->
            <% if(user.role === 'explorer'){ %>

                <div class="mt-4">

                    <% if(!completion){ %>

                        <div class="card shadow">

                            <div class="card-body">

                                <h4>Mark Experience as Completed</h4>

                                <form action="/experiences/<%= experience.id %>/complete" method="POST">

                                    <div class="mb-3">

                                        <label class="form-label">
                                            Rating
                                        </label>

                                        <select
                                            name="rating"
                                            class="form-select"
                                            required>

                                            <option value="">Select Rating</option>
                                            <option value="1">⭐ 1</option>
                                            <option value="2">⭐⭐ 2</option>
                                            <option value="3">⭐⭐⭐ 3</option>
                                            <option value="4">⭐⭐⭐⭐ 4</option>
                                            <option value="5">⭐⭐⭐⭐⭐ 5</option>

                                        </select>

                                    </div>

                                    <div class="mb-3">

                                        <label class="form-label">
                                            Notes
                                        </label>

                                        <textarea
                                            name="notes"
                                            rows="4"
                                            class="form-control"
                                            placeholder="Share your experience..."></textarea>

                                    </div>

                                    <button
                                        class="btn btn-success">

                                        Mark Complete

                                    </button>

                                </form>

                            </div>

                        </div>

                    <% } else { %>

                        <div class="card border-success shadow">

                            <div class="card-body">

                                <h4 class="text-success">

                                    ✅ You have completed this experience!

                                </h4>

                                <hr>

                                <p>

                                    <strong>Rating:</strong>

                                    <%= completion.rating %>/5 ⭐

                                </p>

                                <p>

                                    <strong>Your Notes:</strong><br>

                                    <%= completion.notes || "No notes added." %>

                                </p>

                                <p>

                                    <strong>Completed On:</strong>

                                    <%= new Date(completion.completed_at).toLocaleDateString() %>

                                </p>

                            </div>

                        </div>

                    <% } %>

                </div>

            <% } %>

            <div class="mt-4">

                <a href="/explore" class="btn btn-secondary">

                    ← Back to Explore

                </a>

            </div>

        </div>

    </div>

</div>

</body>
</html>