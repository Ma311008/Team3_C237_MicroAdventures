<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= experience.title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</head>
<body>
<%- include('partials/navbar.ejs') %>

<main class="container my-5">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <% if (successMsg && successMsg.length > 0) { %>
        <div class="alert alert-success">
          <% successMsg.forEach(function(message) { %><p class="mb-0"><%= message %></p><% }); %>
        </div>
      <% } %>
      <% if (errorMsg && errorMsg.length > 0) { %>
        <div class="alert alert-danger">
          <% errorMsg.forEach(function(message) { %><p class="mb-0"><%= message %></p><% }); %>
        </div>
      <% } %>

      <div class="card shadow">
        <div class="card-body">
          <h2 class="card-title mb-3"><%= experience.title %></h2>
          <span class="badge bg-primary mb-3">
            <%= experience.category.charAt(0).toUpperCase() + experience.category.slice(1) %>
          </span>
          <p class="card-text"><strong>Description:</strong><br><%= experience.description %></p>
          <hr>
          <div class="row">
            <div class="col-md-6 mb-3"><strong>Location</strong><br><%= experience.location %></div>
            <div class="col-md-6 mb-3"><strong>Difficulty</strong><br><%= experience.difficulty %></div>
          </div>
        </div>
      </div>

      <% if (user.role === 'explorer') { %>
        <div class="mt-4">
          <% if (!completion) { %>
            <div class="card shadow">
              <div class="card-body">
                <h4>Mark Experience as Completed</h4>
                <p class="text-muted">Record when you completed this adventure and how you would rate it.</p>
                <form action="/experiences/<%= experience.id %>/complete" method="POST" id="completionForm">
                  <div class="mb-3">
                    <label for="rating" class="form-label">Rating *</label>
                    <select id="rating" name="rating" class="form-select" required>
                      <option value="">Select a rating</option>
                      <option value="1">1 - Lowest</option>
                      <option value="2">2</option>
                      <option value="3">3</option>
                      <option value="4">4</option>
                      <option value="5">5 - Highest</option>
                    </select>
                    <div class="form-text">1 is the lowest rating and 5 is the highest.</div>
                  </div>
                  <div class="mb-3">
                    <label for="notes" class="form-label">Notes</label>
                    <textarea id="notes" name="notes" rows="4" maxlength="500" class="form-control"
                              placeholder="Share your experience..."></textarea>
                    <div class="form-text">Optional, up to 500 characters.</div>
                  </div>
                  <div class="mb-3">
                    <label for="completed_at" class="form-label">Completion date *</label>
                    <input type="date" id="completed_at" name="completed_at" class="form-control" required>
                    <div class="form-text">The date cannot be later than today.</div>
                  </div>
                  <button type="submit" class="btn btn-success" id="completionSubmitButton">
                    Mark as Completed
                  </button>
                </form>
              </div>
            </div>
          <% } else { %>
            <div class="card border-success shadow">
              <div class="card-body">
                <h4 class="text-success">You have already completed this experience.</h4>
                <hr>
                <p><strong>Rating:</strong> <%= completion.rating %>/5</p>
                <p><strong>Your Notes:</strong><br><%= completion.notes || 'No notes added.' %></p>
                <p><strong>Completed On:</strong> <%= new Date(completion.completed_at).toLocaleDateString() %></p>
                <a href="/completions/<%= completion.id %>/edit" class="btn btn-outline-primary btn-sm">
                  Edit completion
                </a>
              </div>
            </div>
          <% } %>
        </div>
      <% } else if (user.role === 'admin') { %>
        <div class="alert alert-info mt-4 mb-0">
          Completion tracking is available to explorer accounts.
        </div>
      <% } %>

      <div class="mt-4">
        <a href="/explore" class="btn btn-secondary">Back to Explore</a>
      </div>
    </div>
  </div>
</main>

<script>
  const completionDate = document.getElementById('completed_at');
  if (completionDate) {
    const now = new Date();
    const localToday = new Date(now.getTime() - now.getTimezoneOffset() * 60000)
      .toISOString().split('T')[0];
    completionDate.max = localToday;
    completionDate.value = localToday;
  }

  const completionForm = document.getElementById('completionForm');
  if (completionForm) {
    completionForm.addEventListener('submit', function () {
      if (!this.checkValidity()) return;
      const button = document.getElementById('completionSubmitButton');
      button.disabled = true;
      button.textContent = 'Saving...';
    });
  }
</script>
</body>
</html>
